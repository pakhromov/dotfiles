#!/bin/zsh
arg="$1"

YAZI_ID=$(cat /tmp/yazi_instance_id 2>/dev/null)

if [ -n "$YAZI_ID" ]; then
    if [ -d "$arg" ]; then
        recent=$(ls -tp "$arg" | grep -v '/$' | head -1)
        ya emit-to "$YAZI_ID" plugin --str "write-id" "$arg"
        [ -n "$recent" ] && ya emit-to "$YAZI_ID" reveal --str "$arg/$recent"
    else
        ya emit-to "$YAZI_ID" plugin --str "write-id" "$(dirname "$arg")"
        ya emit-to "$YAZI_ID" reveal --str "$arg"
    fi
    kitty-launch-or-focus.sh yazi
else
    kitty-launch-or-focus.sh yazi "$arg"
fi
