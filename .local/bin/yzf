#!/usr/bin/env bash

version="1.1.5"

export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS
  --ansi --multi --tiebreak=index --exact --reverse --no-hscroll --height=100%
  --preview-window=right:50%:noinfo:wrap
  --highlight-line
  --scroll-off 7
  --info=inline-right
  --border
  --input-border
  --info-command='echo -e \"\$FZF_POS/\$FZF_MATCH_COUNT(\$FZF_SELECT_COUNT)\"'
  --prompt '> '
  --pointer '>'
  --gutter '┃'
  --marker '┃'
  --ellipsis '  '
  --scrollbar ''
  --separator ''
  --color fg:242,bg:233,hl:65,fg+:222,bg+:234,hl+:108
  --color info:108,prompt:110,spinner:150,pointer:167,marker:65
"

_k=$'\033[38;2;160;160;160m'
_a=$'\033[36m'
_r=$'\033[m'
_kb_install=" ${_k}TAB${_a} select   ${_k}ENTER${_a} install   ${_k}ESC${_a} cancel${_r} "
_kb_remove=" ${_k}TAB${_a} select   ${_k}ENTER${_a} remove   ${_k}ESC${_a} cancel${_r} "
_kb_query=" ${_k}TAB${_a} select   ${_k}ESC${_a} cancel${_r} "
_kb_orphans=" ${_k}TAB${_a} select   ${_k}CTRL+A${_a} all   ${_k}ENTER${_a} remove   ${_k}ESC${_a} cancel${_r} "
_kb_upgrade=" ${_k}TAB${_a} select   ${_k}CTRL+A${_a} all   ${_k}RIGHT${_a} url   ${_k}ENTER${_a} upgrade   ${_k}ESC${_a} cancel${_r} "

fzf_preview() {
	printf "yay --color=always %s {1} | " "$1"
	printf "awk '{ sub(/ *:/,\":\"); \$1 = \$1; print }'\n"
}

install() {
	read -ra cmd <<<"$2"

	yay_sl_exit_code=$(mktemp)
	fzf_out=$(mktemp)

	cleanup() { rm -f "$yay_sl_exit_code" "$fzf_out"; }
	trap cleanup EXIT

	coproc PKG_FETCH {
		yay -Sl 2>/dev/null |
			awk '{
				installed = (NF > 3) ? "\033[1;33m* " : ""
				if ($1 == "core") color = "\033[1;31m"
				else if ($1 == "extra") color = "\033[1;32m"
				else if ($1 == "chaotic-aur") color = "\033[1;33m"
				else if ($1 == "cachyos-core-v3") color = "\033[1;35m"
			else if ($1 == "cachyos-v3" || $1 == "cachyos-extra-v3" || $1 == "cachyos") color = "\033[1;34m"
				else if ($1 == "multilib") color = "\033[1;35m"
				else if ($1 == "aur") color = "\033[1;36m"
				else color = "\033[0m"
				printf "%d\t%s %s\033[0m\n", length($2), $2, installed color $1
			}' |
			sort -t$'\t' -k1,1n --stable |
			cut -f2-
		code=${PIPESTATUS[0]}
		[ "$code" -ne 0 ] && printf "%s" "$code" >"$yay_sl_exit_code"
	}

	fzf --border-label ' INSTALL PKG ' --preview "$(fzf_preview -Si)" \
		--preview-label "$_kb_install" --preview-label-pos 'bottom' <&"${PKG_FETCH[0]}" >"$fzf_out"
	[ -n "$PKG_FETCH_PID" ] && kill -TERM "$PKG_FETCH_PID"

	[ ! -s "$yay_sl_exit_code" ] || {
		printf "\033[33;1mwarning:\033[0m failed to fetch the package list" >&2
		printf " (\"yay -Sl\" failed: exit status: %s)\n" "$(cat "$yay_sl_exit_code")" >&2
	}

	awk '{print $NF "/" $1}' "$fzf_out" |
		xargs -ro "${cmd[@]}"
}

query() {
	local label="$1" flags="$2"
	shift 2
	read -ra cmd <<<"$1"
	local kb="${cmd:+$_kb_remove}"
	kb="${kb:-$_kb_query}"

	yay "$flags" --color=always |
		fzf --border-label " $label " --preview "$(fzf_preview -Qi)" \
		--preview-label "$kb" --preview-label-pos 'bottom' |
		awk '{print $1}' |
		xargs -ro "${cmd[@]}"
}

remove_orphans() {
	yay -Qdtq 2>/dev/null |
		fzf --border-label ' REMOVE ORPHANS ' --preview "$(fzf_preview -Qi)" \
		--preview-label "$_kb_orphans" --preview-label-pos 'bottom' \
		--bind "ctrl-a:toggle-all" |
		xargs -ro sudo pacman -Rns
}

high_impact() {
	local results
	results=$(parus-high-impact)
	[ -z "$results" ] && return
	echo "$results" |
		fzf --border-label ' HIGH IMPACT PKG ' --preview "$(fzf_preview -Qi)" \
		--preview-label "$_kb_remove" --preview-label-pos 'bottom' |
		awk '{print $1}' |
		xargs -ro sudo pacman -Rnsc
}

remove_recent() {
	{
		pacman -Qeq
		printf "\n"
		grep '\[ALPM\] installed' /var/log/pacman.log | tac
	} | awk '
		NF == 1 && !sep { explicit[$1] = 1; next }
		NF == 0 { sep = 1; next }
		$4 in explicit {
			gsub(/\[|\]/, "", $1)
			split($1, dt, "T")
			gsub(/\(|\)/, "", $5)
			print $4, "\033[90m" dt[1] " " $5 "\033[0m"
		}
	' |
		fzf --border-label ' REMOVE RECENT PKG ' --preview "$(fzf_preview -Qi)" \
		--preview-label "$_kb_remove" --preview-label-pos 'bottom' |
		awk '{print $1}' |
		xargs -ro sudo pacman -Rnsc
}

format_updates() {
	awk '
function comp(a1, a2, i) {
	h1 = i <= n1
	h2 = i <= n2
	t1 = h1 ? a1[i] : ""
	t2 = h2 ? a2[i] : ""
	if (eq && h1 && h2 && t1 == t2) {
		common = common t1
	} else {
		eq = 0
		if (h1) diff1 = diff1 t1
		if (h2) diff2 = diff2 t2
	}
}
BEGIN {
	expac = "/usr/bin/expac -S \"%r %n\" -"
	while (("pacman -Qmq" | getline pkg) > 0) aur_pkgs[pkg] = 1
	close("pacman -Qmq")
	colors[""] = 37; colors["core"] = 31; colors["extra"] = 32
	colors["multilib"] = 35; colors["aur"] = 34; colors["local"] = 37
	colors["chaotic-aur"] = 33
	colors["cachyos-core-v3"] = 35
	colors["cachyos-v3"] = 36; colors["cachyos-extra-v3"] = 36; colors["cachyos"] = 36
	order["core"] = 1; order["cachyos-core-v3"] = 2
	order["extra"] = 3; order["cachyos-extra-v3"] = 4
	order["cachyos-v3"] = 5; order["cachyos"] = 6
	order["multilib"] = 7; order["chaotic-aur"] = 8
	order["aur"] = 9; order["local"] = 10
}
{
	pkgs[NR] = $1; v1_arr[NR] = $2; v2_arr[NR] = $4
	if (length($1) > l_pkg) l_pkg = length($1)
	if (length($2) > l_v1) l_v1 = length($2)
	if (length($4) > l_v2) l_v2 = length($4)
	print $1 |& expac
}
END {
	if (NR == 0) exit
	close(expac, "to")
	while ((expac |& getline) > 0) {
		repo_map[$2] = $1
		if (length($1) > l_repo) l_repo = length($1)
	}
	close(expac)
	if (length("aur") > l_repo) l_repo = length("aur")
	l_pkgname = l_repo + 1 + l_pkg
	for (j = 1; j <= NR; j++) {
		p = pkgs[j]
		if (p in repo_map) r = repo_map[p]
		else if (p in aur_pkgs) r = "aur"
		else r = "local"
		o = (r in order) ? order[r] : 9
		sort_proxy[j] = sprintf("%d %s", o, p) SUBSEP j
	}
	n = asort(sort_proxy)
	for (i = 1; i <= n; i++) {
		split(sort_proxy[i], parts, SUBSEP)
		orig_idx = parts[2]
		pkg = pkgs[orig_idx]; v1 = v1_arr[orig_idx]; v2 = v2_arr[orig_idx]
		if (pkg in repo_map) repo = repo_map[pkg]
		else if (pkg in aur_pkgs) repo = "aur"
		else repo = "local"
		color = repo in colors ? colors[repo] : colors[""]
		eq = 1; common = ""; diff1 = ""; diff2 = ""
		n1 = split(v1, arr1, /[-.:]/, sep1)
		n2 = split(v2, arr2, /[-.:]/, sep2)
		comp(sep1, sep2, 0)
		for (k = 1; k <= (n1 > n2 ? n1 : n2); k++) {
			comp(arr1, arr2, k)
			comp(sep1, sep2, k)
		}
		printf "\033[1;%sm%s\033[0m\033[1m/%s\033[0m", color, repo, pkg
		printf "%*s  ", (l_pkgname - length(repo) - length(pkg) - 1), ""
		printf "%s\033[31m%s\033[0m%-*s -> %s\033[32m%s\033[0m\n", common, diff1, (l_v1 - length(v1)), "", common, diff2
	}
}'
}

upgrade() {
	local pkgs
	# checkupdates for official repos (no sudo needed), yay -Qua for AUR
	pkgs=$({ checkupdates 2>/dev/null; yay -Qua 2>/dev/null; })

	[ -z "$pkgs" ] &&
		printf "there is no upgradable package\n" && return

	local formatted
	formatted=$(format_updates <<<"$pkgs")

	local selected
	selected=$(fzf --no-sort --border-label ' SYSTEM UPDATE ' \
		--bind "load:select-all" \
		--bind "ctrl-a:toggle-all" \
		--bind "right:execute-silent(pkg=\$(echo {} | awk -F'/' '{print \$2}' | awk '{print \$1}'); url=\$(expac -S '%u' \"\$pkg\" 2>/dev/null | head -1); [ -z \"\$url\" ] && url=\$(yay -Si \"\$pkg\" 2>/dev/null | awk '/^URL/ {print \$3}'); [ -n \"\$url\" ] && xdg-open \"\$url\")" \
		<<<"$formatted")

	[ -z "$selected" ] && return

	# Strip ANSI codes and split into repo/pkg pairs
	parsed=$(awk -F'/' '{
		repo = $1; gsub(/\033\[[0-9;]*m/, "", repo)
		pkg = $2; gsub(/\033\[[0-9;]*m/, "", pkg); split(pkg, a, " "); pkg = a[1]
		print repo"\t"pkg
	}' <<<"$selected")

	# Install official packages first (core/extra/multilib), then AUR
	official=$(awk -F'\t' '$1 != "aur" && $1 != "local" {print $2}' <<<"$parsed")
	aur=$(awk -F'\t' '$1 == "aur" || $1 == "local" {print $2}' <<<"$parsed")

	status=0
	[ -n "$official" ] && { xargs -ro sudo pacman -Sy --needed --noconfirm <<<"$official" || status=1; }
	[ -n "$aur" ] && { xargs -ro yay -S --needed --noconfirm <<<"$aur" || status=1; }

	if [ $status -eq 0 ]; then
		printf "\033[1;32mUpdate successful\033[0m\n"
	else
		printf "\033[1;31mUpdate failed\033[0m\n"
	fi

	read -rsn1 -p "Press enter or esc to exit..."
}

help() {
	prog=$(basename "$0")
	cat <<EOF
Info:
    $prog v$version
    A package search TUI for Yay, powered by fzf.
    It can install, upgrade, remove, and query packages.

Usage:
    $prog       -> Default action
    $prog [opt] -> Other options

    The default action is to search for and install packages.
    A '*' indicates that the package is already installed.

Multiple Selection:
    Tab         -> Select / Deselect
    Ctrl + i    -> Select / Deselect

Options:
    h -> Print this message
    p -> Print only; do not install
    u -> Upgrade upgradable packages
    r -> Remove installed packages
    R -> Remove explicitly installed packages
    x -> Remove recently installed packages
    o -> Remove orphan packages
    H -> High-impact removals (by size)
    q -> Show installed packages
    Q -> Show explicitly installed packages
EOF
}

invalid_option() {
	printf "\033[1mError:\033[0m Invalid option. " >&2
	printf "Use \"%s --help\" for more information.\n" "$(basename "$0")" >&2
	exit 2
}

[ -n "$2" ] && invalid_option
case $1 in
"") install ":" "yay -S --needed" ;;
-p | p) install "p" ;;
-u | u) upgrade ;;
-r | r) query "REMOVE PKG" "-Q" "sudo pacman -Rnsc" ;;
-R | R) query "REMOVE EXPLICITLY PKG" "-Qe" "sudo pacman -Rnsc" ;;
-x | x) remove_recent ;;
-o | o) remove_orphans ;;
-H | H) high_impact ;;
-q | q) query "INSTALLED PKG" "-Q" ;;
-Q | Q) query "INSTALLED EXPLICITLY PKG" "-Qe" ;;
-h | h | --help) help ;; *) invalid_option ;;
esac
