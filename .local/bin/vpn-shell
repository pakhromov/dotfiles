#!/usr/bin/env bash
# Usage: vpn-shell [wg-conf] [command...]
# Opens a shell (or runs a command) in a network namespace routed through WireGuard.
set -eu

CONF="${1:-/home/pavel/.config/wireguard/proton.conf}"
NS="vpn$$"
WG="wg$$"
TMPKEY=$(mktemp)
chmod 600 "$TMPKEY"

_mpv_fifo=$(mktemp -u /tmp/vpn-mpv.XXXXXX)
mkfifo -m 600 "$_mpv_fifo"
# Open R+W so the open() call never blocks (FIFO is its own reader+writer)
exec 3<>"$_mpv_fifo"
# Listener runs in host network namespace — mpv gets unrestricted network
while IFS= read -r _url; do
    mpv "$_url" &
done <"$_mpv_fifo" &
_mpv_pid=$!

cleanup() {
    exec 3>&-
    kill "$_mpv_pid" 2>/dev/null || true
    sudo ip netns del "$NS"       2>/dev/null || true
    sudo rm -rf "/etc/netns/$NS"  2>/dev/null || true
    rm -f "$TMPKEY" "${TMPKEY}.psk" "$_mpv_fifo"
}
trap cleanup EXIT INT TERM

get() { awk "/^${1} *=/{sub(/^[^=]+=[ ]*/,\"\"); print; exit}" "$CONF"; }

privkey=$(get PrivateKey)
address=$(get Address)
dns=$(get DNS)
pubkey=$(get PublicKey)
endpoint=$(get Endpoint)
allowed=$(get AllowedIPs | tr -d ' ')
psk=$(get PresharedKey)
keepalive=$(get PersistentKeepalive)

echo "$privkey" > "$TMPKEY"

sudo ip netns add "$NS"
sudo ip netns exec "$NS" ip link set lo up

sudo ip link add "$WG" type wireguard
sudo ip link set "$WG" netns "$NS"

peer_args=(peer "$pubkey" allowed-ips "$allowed" endpoint "$endpoint")
if [[ -n "$psk" ]]; then
    echo "$psk" > "${TMPKEY}.psk"
    chmod 600 "${TMPKEY}.psk"
    peer_args+=(preshared-key "${TMPKEY}.psk")
fi
[[ -n "$keepalive" ]] && peer_args+=(persistent-keepalive "$keepalive")

sudo ip netns exec "$NS" wg set "$WG" private-key "$TMPKEY" "${peer_args[@]}"
while IFS= read -r addr; do
    addr="${addr// /}"
    [[ -n "$addr" ]] && sudo ip netns exec "$NS" ip addr add "$addr" dev "$WG"
done < <(echo "$address" | tr ',' '\n')
sudo ip netns exec "$NS" ip link set "$WG" up
sudo ip netns exec "$NS" ip route add default dev "$WG"

sudo mkdir -p "/etc/netns/$NS"
{ echo "$dns" | tr ',' '\n' | while read -r s; do
    s="${s// /}"
    [[ -n "$s" ]] && printf 'nameserver %s\n' "$s"
  done
  printf 'nameserver 1.1.1.1\n'
} | sudo tee "/etc/netns/$NS/resolv.conf" > /dev/null

# Wait for WireGuard handshake
printf 'Waiting for handshake...' >&2
for i in $(seq 1 15); do
    if sudo ip netns exec "$NS" wg show "$WG" latest-handshakes | grep -qv '^$\|	0$'; then
        printf ' \033[1;32mok\033[0m\n' >&2
        break
    fi
    printf '.' >&2
    sleep 1
done

printf '\033[1;32mVPN up\033[0m (%s)\n' "$(basename "$CONF" .conf)" >&2

_env=(HOME="$HOME" PATH="$PATH" USER="$USER" LOGNAME="$USER"
      TERM="${TERM:-xterm}" SHELL="$SHELL")
[[ -n "${WAYLAND_DISPLAY:-}"          ]] && _env+=(WAYLAND_DISPLAY="$WAYLAND_DISPLAY")
[[ -n "${DISPLAY:-}"                  ]] && _env+=(DISPLAY="$DISPLAY")
[[ -n "${XDG_RUNTIME_DIR:-}"          ]] && _env+=(XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR")
[[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]] && _env+=(DBUS_SESSION_BUS_ADDRESS="$DBUS_SESSION_BUS_ADDRESS")
_env+=(VPN_MPV_FIFO="$_mpv_fifo")

if [[ $# -gt 1 ]]; then
    sudo ip netns exec "$NS" runuser -u "$USER" -- env "${_env[@]}" "${@:2}"
else
    sudo ip netns exec "$NS" runuser -u "$USER" -- env "${_env[@]}" "$SHELL"
fi
