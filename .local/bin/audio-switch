#!/bin/bash

export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS
  --no-sort --exact --reverse --no-hscroll --height=100%
  --highlight-line --scroll-off 7 --info=inline-right
  --border --input-border
  --prompt '> ' --pointer '>' --gutter '┃' --marker '┃'
  --ellipsis '  ' --scrollbar '' --separator ''
  --color fg:242,bg:233,hl:65,fg+:222,bg+:234,hl+:108
  --color info:108,prompt:110,spinner:150,pointer:167,marker:65
"

parse() {
    grep "^card" | grep -v "Loopback" | \
    sed -n 's/card \([0-9]*\): [^[]*\[\([^]]*\)\], device \([0-9]*\): [^[]*\[\([^]]*\)\]/card=\1 device=\3 | \2 — \4/p'
}

write_asoundrc() {
    local card=$1 dev=$2
    cat > ~/.asoundrc << EOF
pcm.!default {
    type plug
    slave.pcm {
        type hw
        card $card
        device $dev
    }
}
ctl.!default {
    type hw
    card $card
}
EOF
}

write_asoundrc_defaults() {
    local card=$1 dev=$2
    cat > ~/.asoundrc << EOF
defaults.ctl.card $card
defaults.pcm.card $card
defaults.pcm.device $dev
EOF
}

case "$1" in
    -d)
        selection=$(aplay -l | parse | grep -i "Sennheiser" | head -1)
        [[ -z "$selection" ]] && { echo "Sennheiser device not found"; cat > ~/.asoundrc << 'EOF'
pcm.!default { type null }
ctl.!default { type null }
EOF
exit 1; }
        ;;
    *)
        selection=$(aplay -l | parse | fzf --border-label ' AUDIO OUTPUT ')
        [[ -z "$selection" ]] && exit 0
        ;;
esac

card=$(echo "$selection" | grep -oP 'card=\K[0-9]+')
dev=$(echo "$selection"  | grep -oP 'device=\K[0-9]+')
if [[ "$1" == "-d" ]]; then
    write_asoundrc_defaults "$card" "$dev"
else
    write_asoundrc "$card" "$dev"
fi
echo "Set: $(echo "$selection" | cut -d'|' -f2 | xargs) (card $card, device $dev)"
aplay -D dmix:$card -f S16_LE -r 48000 -c 2 -d 1 -t raw /dev/zero &
